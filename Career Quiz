<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Career Compass</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--navy:#0f1e35;--blue:#1a56db;--lblue:#3b82f6;--accent:#f59e0b;--gold:#eab308;--surface:#fff;--s2:#f1f5f9;--s3:#e2e8f0;--border:#e2e8f0;--text:#1e293b;--muted:#64748b;--r:12px;--green:#059669;--red:#dc2626;--purple:#7c3aed}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:linear-gradient(135deg,#0f1e35,#1e293b);min-height:100vh;display:flex;align-items:center;justify-content:center;color:var(--text);padding:20px}
.wrap{width:100%;max-width:720px}

/* INTRO */
.intro-card{background:#fff;border-radius:20px;padding:56px 48px;box-shadow:0 25px 60px rgba(0,0,0,.3);text-align:center}
.badge{display:inline-block;background:#eff6ff;color:var(--blue);font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:100px;margin-bottom:24px}
.intro-title{font-size:38px;font-weight:900;color:var(--text);margin-bottom:16px;line-height:1.15}
.intro-desc{font-size:16px;color:var(--muted);line-height:1.7;max-width:460px;margin:0 auto 32px}
.intro-meta{display:flex;justify-content:center;gap:40px;margin-bottom:36px}
.im-val{font-size:24px;font-weight:800;color:var(--text)}
.im-lbl{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-top:2px}
.start-btn{display:inline-block;padding:18px 52px;border:none;border-radius:10px;background:var(--blue);color:#fff;font-size:16px;font-weight:700;cursor:pointer;box-shadow:0 8px 24px rgba(26,86,219,.35);transition:all .2s}
.start-btn:hover{background:#1347b3;transform:translateY(-2px);box-shadow:0 12px 28px rgba(26,86,219,.45)}

/* QUIZ HEADER */
.quiz-hdr{text-align:center;margin-bottom:24px}
.logo{font-size:12px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--accent)}
.prog-wrap{margin-bottom:22px}
.prog-meta{display:flex;justify-content:space-between;margin-bottom:8px;color:rgba(255,255,255,.55);font-size:13px}
.prog-track{height:5px;background:rgba(255,255,255,.12);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--lblue),var(--accent));border-radius:3px;transition:width .5s ease}

/* CARD */
.card{background:#fff;border-radius:20px;padding:40px 42px;box-shadow:0 25px 60px rgba(0,0,0,.3);position:relative;overflow:hidden;transition:opacity .22s,transform .22s}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--blue),var(--lblue),var(--accent))}
.q-num{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--lblue);margin-bottom:12px}
.q-text{font-size:22px;font-weight:700;color:var(--text);line-height:1.35;margin-bottom:6px}
.q-sub{font-size:14px;color:var(--muted);margin-bottom:26px;line-height:1.5}

/* NAV */
.nav{display:flex;justify-content:space-between;align-items:center;margin-top:32px}
.btn-back{padding:12px 22px;border:2px solid var(--border);border-radius:8px;background:transparent;color:var(--muted);font-size:14px;font-weight:600;cursor:pointer;transition:all .18s}
.btn-back:hover{border-color:var(--muted);color:var(--text)}
.btn-next{padding:14px 30px;border:none;border-radius:8px;background:var(--blue);color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:all .18s;box-shadow:0 4px 14px rgba(26,86,219,.3)}
.btn-next:hover:not(:disabled){background:#1347b3;transform:translateY(-1px);box-shadow:0 6px 18px rgba(26,86,219,.4)}
.btn-next:disabled{background:var(--border);color:var(--muted);cursor:not-allowed;box-shadow:none}

/* VISUAL CARDS (stage) */
.vcards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.vcard{padding:30px 16px;border:2px solid var(--border);border-radius:14px;cursor:pointer;text-align:center;transition:all .22s;background:#fff}
.vcard:hover{border-color:var(--lblue);transform:translateY(-3px);background:#f8faff}
.vcard.sel{border-color:var(--blue);background:#eff6ff;box-shadow:0 8px 20px rgba(26,86,219,.15)}
.vcard-icon{font-size:48px;margin-bottom:10px;line-height:1}
.vcard-lbl{font-size:14px;font-weight:700;color:var(--text)}

/* TAG CLOUD */
.tags{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;padding:8px 0}
.tag{padding:10px 16px;border:2px solid var(--border);border-radius:100px;cursor:pointer;font-size:14px;font-weight:600;color:var(--text);background:#fff;transition:all .25s;user-select:none}
.tag:hover{border-color:var(--lblue);background:#f8faff}
.tag.sel{border-color:var(--blue);background:var(--blue);color:#fff;font-size:16px;padding:12px 20px;box-shadow:0 4px 14px rgba(26,86,219,.3)}
.tag-counter{text-align:center;font-size:13px;color:var(--muted);margin-top:14px}

/* TEXT INPUT */
.text-input-wrap{position:relative}
.text-input{width:100%;padding:18px 20px;border:2px solid var(--border);border-radius:12px;font-size:16px;font-family:inherit;color:var(--text);outline:none;transition:border .18s}
.text-input:focus{border-color:var(--blue)}
.school-suggest{position:absolute;left:0;right:0;background:#fff;border:2px solid var(--blue);border-top:none;border-radius:0 0 12px 12px;max-height:200px;overflow-y:auto;z-index:10;box-shadow:0 6px 16px rgba(0,0,0,.12)}
.sug-item{padding:12px 18px;cursor:pointer;font-size:14px;border-bottom:1px solid var(--s2)}
.sug-item:hover{background:#eff6ff}
.sug-item:last-child{border-bottom:none}
.text-meta{font-size:12px;color:var(--green);margin-top:10px;font-weight:600}

/* PAIRWISE */
.pairs-prog{text-align:center;font-size:12px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:18px}
.pair-vs{display:grid;grid-template-columns:1fr 60px 1fr;gap:12px;align-items:center;margin-bottom:8px}
.pair-card{padding:38px 20px;border:2px solid var(--border);border-radius:16px;cursor:pointer;text-align:center;font-size:17px;font-weight:700;color:var(--text);background:#fff;transition:all .2s;min-height:140px;display:flex;align-items:center;justify-content:center}
.pair-card:hover{border-color:var(--blue);background:#eff6ff;transform:scale(1.03)}
.pair-vs-mid{font-size:22px;font-weight:900;color:var(--accent);text-align:center}

/* THREE-BUCKET */
.bucket-items{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;padding:14px;background:var(--s2);border-radius:12px;margin-bottom:16px;min-height:60px}
.b-item{padding:9px 14px;background:#fff;border:2px solid var(--border);border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .18s}
.b-item:hover{border-color:var(--lblue);background:#eff6ff}
.b-item.sel{border-color:var(--accent);background:#fef3c7}
.buckets{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.bucket{padding:14px;border:2px dashed var(--border);border-radius:12px;min-height:120px;cursor:pointer;transition:all .18s;background:#fafbfc}
.bucket:hover{border-color:var(--lblue);background:#f0f7ff}
.bucket.active{border-color:var(--blue);background:#eff6ff;border-style:solid}
.bucket-title{font-size:12px;font-weight:700;text-align:center;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
.bucket.low .bucket-title{color:#94a3b8}
.bucket.mid .bucket-title{color:var(--blue)}
.bucket.high .bucket-title{color:var(--accent)}
.bucket-content{display:flex;flex-direction:column;gap:6px}
.bucket-item{padding:6px 10px;background:#fff;border:1px solid var(--border);border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;text-align:center}
.bucket-item:hover{background:#fee2e2;border-color:var(--red)}
.bucket-hint{text-align:center;font-size:12px;color:var(--muted);margin-top:10px}

/* MULTIPLE CHOICE */
.opts{display:flex;flex-direction:column;gap:10px}
.opt{display:flex;align-items:center;gap:14px;padding:15px 18px;border:2px solid var(--border);border-radius:var(--r);background:#fff;cursor:pointer;transition:all .18s;text-align:left;width:100%}
.opt:hover{border-color:var(--lblue);background:#eff6ff}
.opt.sel{border-color:var(--blue);background:#eff6ff}
.opt-letter{width:30px;height:30px;border-radius:50%;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--muted);flex-shrink:0;transition:all .18s}
.opt.sel .opt-letter{background:var(--blue);color:#fff}
.opt-text{font-size:15px;color:var(--text);line-height:1.4}

/* VISUAL CARD PICKER (3 of 9) */
.vpicker{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.vpick{padding:18px 8px;border:2px solid var(--border);border-radius:12px;cursor:pointer;text-align:center;transition:all .2s;background:#fff;position:relative}
.vpick:hover{border-color:var(--lblue);background:#f8faff;transform:translateY(-2px)}
.vpick.sel{border-color:var(--blue);background:#eff6ff;box-shadow:0 6px 18px rgba(26,86,219,.2)}
.vpick.disabled{opacity:.4;cursor:not-allowed}
.vpick-icon{font-size:32px;margin-bottom:8px;line-height:1}
.vpick-lbl{font-size:12px;font-weight:700;color:var(--text);line-height:1.3}
.vpick-num{position:absolute;top:6px;right:6px;width:22px;height:22px;border-radius:50%;background:var(--blue);color:#fff;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center}
.vpicker-hint{text-align:center;margin-top:14px;font-size:13px;color:var(--muted)}

/* SLIDER */
.slider-wrap{margin-top:8px}
.slider-labels{display:flex;justify-content:space-between;margin-bottom:14px;font-size:13px;color:var(--muted);font-weight:500}
input[type=range]{width:100%;-webkit-appearance:none;height:6px;border-radius:3px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:24px;height:24px;border-radius:50%;background:var(--blue);box-shadow:0 2px 10px rgba(26,86,219,.45);cursor:pointer;transition:transform .15s}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.15)}
.slider-val{text-align:center;margin-top:14px;font-size:14px;font-weight:700;color:var(--blue)}

/* 2D MAP */
.map2d-wrap{position:relative;margin:8px 0}
.map2d{position:relative;width:100%;aspect-ratio:1;background:linear-gradient(135deg,#f1f5f9,#fff);border:2px solid var(--border);border-radius:16px;cursor:crosshair;overflow:hidden}
.map-axis-h,.map-axis-v{position:absolute;background:var(--border)}
.map-axis-h{left:0;right:0;top:50%;height:1px}
.map-axis-v{top:0;bottom:0;left:50%;width:1px}
.map-lbl{position:absolute;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.map-lbl.top{top:10px;left:50%;transform:translateX(-50%)}
.map-lbl.bot{bottom:10px;left:50%;transform:translateX(-50%)}
.map-lbl.left{left:10px;top:50%;transform:translateY(-50%) rotate(-90deg);transform-origin:center}
.map-lbl.right{right:10px;top:50%;transform:translateY(-50%) rotate(90deg);transform-origin:center}
.map-dot{position:absolute;width:24px;height:24px;border-radius:50%;background:var(--blue);box-shadow:0 4px 14px rgba(26,86,219,.5);transform:translate(-50%,-50%);transition:left .15s,top .15s;border:3px solid #fff;pointer-events:none}
.map-hint{text-align:center;font-size:13px;color:var(--muted);margin-top:10px}

/* GPA */
.gpa-wrap{text-align:center;padding:14px 0}
.gpa-display{font-size:64px;font-weight:900;color:var(--blue);line-height:1;margin-bottom:6px}
.gpa-feedback{font-size:13px;color:var(--muted);font-weight:600;min-height:18px;margin-bottom:24px;transition:color .25s}
.gpa-feedback.good{color:var(--green)}
.gpa-feedback.great{color:var(--accent)}
.gpa-feedback.elite{color:var(--purple)}

/* EMOJI GRID */
.emoji-rows{display:flex;flex-direction:column;gap:12px}
.emoji-row{display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;padding:14px;border:2px solid var(--border);border-radius:12px;background:#fff}
.emoji-statement{font-size:14px;font-weight:600;color:var(--text);line-height:1.4}
.emoji-pick{display:flex;gap:6px}
.emo-btn{width:42px;height:42px;border:2px solid var(--border);border-radius:50%;font-size:22px;cursor:pointer;background:#fff;transition:all .18s;display:flex;align-items:center;justify-content:center;line-height:1}
.emo-btn:hover{border-color:var(--lblue);transform:scale(1.1)}
.emo-btn.sel{border-color:var(--blue);background:#eff6ff;transform:scale(1.15)}

/* DIAL */
.dial-wrap{display:flex;flex-direction:column;align-items:center;padding:10px}
.dial-svg{width:240px;height:140px;cursor:pointer}
.dial-val{font-size:36px;font-weight:900;color:var(--blue);margin-top:6px;line-height:1}
.dial-lbl{font-size:13px;font-weight:600;color:var(--muted);margin-top:4px;min-height:18px}

/* TIER LIST */
.tier-pool{display:flex;flex-wrap:wrap;gap:8px;padding:14px;background:var(--s2);border-radius:12px;margin-bottom:14px;min-height:50px}
.t-item{padding:8px 14px;background:#fff;border:2px solid var(--border);border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s}
.t-item:hover{border-color:var(--lblue);background:#eff6ff}
.t-item.sel{border-color:var(--accent);background:#fef3c7;transform:scale(1.05)}
.tiers{display:flex;flex-direction:column;gap:6px}
.tier-row{display:grid;grid-template-columns:60px 1fr;gap:10px;align-items:stretch}
.tier-lbl{display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:900;color:#fff;border-radius:10px;cursor:pointer;transition:all .18s}
.tier-lbl.S{background:linear-gradient(135deg,#dc2626,#ef4444)}
.tier-lbl.A{background:linear-gradient(135deg,#f59e0b,#fbbf24)}
.tier-lbl.B{background:linear-gradient(135deg,#3b82f6,#60a5fa)}
.tier-lbl.C{background:linear-gradient(135deg,#64748b,#94a3b8)}
.tier-zone{min-height:50px;padding:8px;border:2px dashed var(--border);border-radius:10px;display:flex;flex-wrap:wrap;gap:6px;align-content:center;cursor:pointer;transition:all .18s}
.tier-zone:hover{border-color:var(--blue);background:#fafbfc}
.tier-zone.active{border-color:var(--blue);background:#eff6ff;border-style:solid}
.tier-item{padding:5px 10px;background:#fff;border:1px solid var(--border);border-radius:6px;font-size:11px;font-weight:700;cursor:pointer}
.tier-item:hover{background:#fee2e2;border-color:var(--red)}
.tier-hint{text-align:center;font-size:12px;color:var(--muted);margin-top:10px}

/* SPECTRUM W/ MARKERS */
.spec-track-wrap{padding:30px 0 20px}
.spec-track{position:relative;height:8px;background:linear-gradient(90deg,var(--lblue),var(--accent));border-radius:4px;margin:30px 0}
.spec-marker{position:absolute;top:50%;width:16px;height:16px;border-radius:50%;background:#fff;border:3px solid var(--lblue);transform:translate(-50%,-50%);cursor:pointer;transition:all .18s;z-index:1}
.spec-marker:hover{transform:translate(-50%,-50%) scale(1.3)}
.spec-marker.sel{background:var(--blue);transform:translate(-50%,-50%) scale(1.5);box-shadow:0 4px 14px rgba(26,86,219,.5)}
.spec-stops{display:flex;justify-content:space-between;margin-top:14px}
.spec-stop{font-size:11px;text-align:center;width:18%;font-weight:600;color:var(--muted);cursor:pointer;transition:color .18s}
.spec-stop.sel{color:var(--blue)}
.spec-display{text-align:center;font-size:15px;font-weight:700;color:var(--text);margin-top:18px;min-height:22px}

/* BUDGET ALLOCATOR */
.budget-info{display:flex;justify-content:space-between;align-items:center;padding:14px 18px;background:var(--s2);border-radius:10px;margin-bottom:16px;font-size:14px;font-weight:700}
.budget-rem{color:var(--blue);font-size:22px}
.budget-rem.over{color:var(--red)}
.budget-rem.ok{color:var(--green)}
.budget-rows{display:flex;flex-direction:column;gap:10px}
.budget-row{display:grid;grid-template-columns:130px 1fr 44px;gap:10px;align-items:center}
.budget-lbl{font-size:13px;font-weight:700;color:var(--text)}
.budget-bar{position:relative;height:30px;background:var(--s2);border-radius:8px;overflow:hidden}
.budget-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--lblue));transition:width .15s;border-radius:8px}
.budget-val{font-size:13px;font-weight:800;text-align:right;color:var(--blue)}
.budget-controls{display:flex;align-items:center;gap:4px;justify-content:center}
.b-btn{width:26px;height:26px;border:1px solid var(--border);border-radius:6px;background:#fff;cursor:pointer;font-size:14px;font-weight:800;color:var(--text)}
.b-btn:hover{background:var(--s2)}
.budget-bar-wrap{position:relative}
.budget-bar-wrap input[type=range]{position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:pointer;margin:0;padding:0}

/* SWIPE STACK */
.swipe-prog{text-align:center;font-size:12px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:14px}
.swipe-card{padding:42px 22px;border:2px solid var(--border);border-radius:18px;text-align:center;font-size:18px;font-weight:700;color:var(--text);background:linear-gradient(135deg,#fff,#f8faff);min-height:160px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;line-height:1.4}
.swipe-btns{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.sw-btn{padding:18px;border:2px solid var(--border);border-radius:12px;background:#fff;font-size:16px;font-weight:800;cursor:pointer;transition:all .18s}
.sw-yes{color:var(--green);border-color:#bbf7d0}
.sw-yes:hover{background:#dcfce7;border-color:var(--green);transform:translateY(-2px)}
.sw-no{color:var(--red);border-color:#fecaca}
.sw-no:hover{background:#fee2e2;border-color:var(--red);transform:translateY(-2px)}

/* RANKING */
.rank-list{display:flex;flex-direction:column;gap:10px}
.rank-item{display:flex;align-items:center;gap:14px;padding:13px 17px;border:2px solid var(--border);border-radius:var(--r);cursor:pointer;transition:all .18s;background:#fff;user-select:none}
.rank-item:hover:not(.rked){border-color:var(--lblue);background:#f8faff}
.rank-item.rked{border-color:var(--blue);background:#eff6ff}
.rank-badge{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;background:var(--s2);color:var(--muted);flex-shrink:0;transition:all .18s}
.rank-item.rked .rank-badge{background:var(--blue);color:#fff}
.rank-text{font-size:15px;color:var(--text)}
.rank-hint{font-size:13px;color:var(--muted);margin-bottom:14px}

/* COMBO POPUP */
.combo-overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);display:flex;align-items:center;justify-content:center;z-index:1000;opacity:0;transition:opacity .3s;pointer-events:none;padding:20px}
.combo-overlay.vis{opacity:1;pointer-events:all}
.combo-modal{background:#fff;border-radius:24px;padding:46px 36px;max-width:400px;width:100%;text-align:center;transform:scale(.85);transition:transform .35s cubic-bezier(.34,1.56,.64,1)}
.combo-overlay.vis .combo-modal{transform:scale(1)}
.combo-lbl{font-size:54px;font-weight:900;margin-bottom:6px;letter-spacing:-1.5px}
.combo-title{font-size:20px;font-weight:800;color:var(--text);margin-bottom:10px}
.combo-desc{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:24px}
.combo-btn{padding:12px 32px;border:none;border-radius:8px;background:var(--blue);color:#fff;font-size:15px;font-weight:700;cursor:pointer}

/* RESULTS */
.res-hdr{text-align:center;margin-bottom:24px}
.res-eye{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--lblue);margin-bottom:10px}
.res-title{font-size:28px;font-weight:900;color:var(--text);margin-bottom:8px;line-height:1.2}
.res-sub{font-size:14px;color:var(--muted);line-height:1.5;max-width:480px;margin:0 auto}
.archetype-card{padding:28px;border-radius:16px;background:linear-gradient(135deg,#1a56db,#7c3aed);color:#fff;margin-bottom:24px;text-align:center}
.arche-eye{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;opacity:.85;margin-bottom:8px}
.arche-name{font-size:32px;font-weight:900;margin-bottom:10px;letter-spacing:-.5px}
.arche-blurb{font-size:15px;line-height:1.65;opacity:.95}
.ind-card{padding:20px;border-radius:14px;margin-bottom:14px;border:2px solid var(--border);transition:all .2s}
.ind-card.top{border-color:var(--blue);background:linear-gradient(135deg,#eff6ff,#fff)}
.ind-head{display:flex;align-items:center;gap:14px;margin-bottom:12px}
.ind-rank{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0;background:var(--s2);color:var(--muted)}
.ind-card.top .ind-rank{background:var(--blue);color:#fff}
.ind-name{font-size:18px;font-weight:800;color:var(--text);flex:1}
.ind-pct{font-size:18px;font-weight:900;color:var(--blue)}
.ind-bar{height:5px;background:var(--s2);border-radius:3px;overflow:hidden;margin-bottom:14px}
.ind-bar-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--lblue));border-radius:3px}
.ind-why{font-size:14px;color:var(--text);line-height:1.6;margin-bottom:12px}
.ind-school{padding:14px;background:#fef9e7;border-left:3px solid var(--accent);border-radius:8px;font-size:13px;line-height:1.6;color:var(--text)}
.ind-school strong{color:var(--accent);display:block;margin-bottom:4px;font-size:11px;letter-spacing:1px;text-transform:uppercase}
.ind-school .major{font-weight:800;color:var(--text);font-size:14px}
.ind-classes{margin-top:8px;font-size:12px;color:var(--muted)}
.ind-classes strong{color:var(--text)}
.gpa-banner{padding:18px 22px;border-radius:12px;margin-bottom:18px;text-align:center;font-size:14px;font-weight:600;line-height:1.5}
.gpa-banner.elite{background:linear-gradient(135deg,#fef3c7,#fde68a);color:#78350f;border:2px solid #f59e0b}
.gpa-banner.great{background:#dcfce7;color:#14532d;border:2px solid var(--green)}
.gpa-banner.good{background:#dbeafe;color:#1e3a8a;border:2px solid var(--blue)}
.gpa-banner.solid{background:#f1f5f9;color:#334155;border:2px solid var(--border)}
.restart{display:block;width:100%;padding:14px;margin-top:20px;border:2px solid var(--border);border-radius:8px;background:transparent;color:var(--muted);font-size:14px;font-weight:600;cursor:pointer;transition:all .18s}
.restart:hover{border-color:var(--blue);color:var(--blue)}

.hidden{display:none!important}
@media(max-width:540px){
  .card{padding:30px 24px}
  .intro-card{padding:40px 28px}
  .intro-title{font-size:28px}
  .vcards,.vpicker{grid-template-columns:repeat(2,1fr)}
  .buckets{grid-template-columns:1fr;gap:12px}
  .pair-vs{grid-template-columns:1fr;gap:6px}
  .pair-vs-mid{padding:4px 0}
  .budget-row{grid-template-columns:90px 1fr 40px}
}
