function renderQ(idx){
  const q=Qs[idx];
  const pct=Math.round(((idx+1)/Qs.length)*100);
  document.getElementById('q-label').textContent=`Question ${idx+1} of ${Qs.length}`;
  document.getElementById('q-pct').textContent=`${pct}%`;
  document.getElementById('prog-fill').style.width=`${pct}%`;

  let h=`<div class="q-num">Question ${idx+1} / ${Qs.length}</div><div class="q-text">${q.q}</div>`;
  if(q.sub) h+=`<div class="q-sub">${q.sub}</div>`;
  let inputHtml='';
  try {
    inputHtml=renderInput(q,idx);
  } catch (err) {
    console.error('Render error on Q'+(idx+1)+':',err);
    inputHtml=`<div style="padding:30px;background:#fef2f2;border:2px solid #fecaca;border-radius:12px;text-align:center;color:#991b1b">
      <div style="font-weight:700;margin-bottom:8px">This question had a rendering issue.</div>
      <div style="font-size:13px;margin-bottom:14px">You can skip ahead — your earlier answers are saved.</div>
      <button class="btn-next" onclick="forceNext()">Skip this question →</button>
    </div>`;
  }
  h+=inputHtml;

  const isLast=idx===Qs.length-1;
  const ok=canNext(q);
  h+=`<div class="nav">
    <button class="btn-back" onclick="goBack()" style="${idx===0?'visibility:hidden':''}">← Back</button>
    <button class="btn-next" id="btn-next" onclick="goNext()" ${ok?'':'disabled'}>${isLast?'See Results →':'Next →'}</button>
  </div>`;
  document.getElementById('qcard').innerHTML=h;

  // Post-mount setup for some types
  if(q.type==='map2d') setupMap();
  if(q.type==='dial') setupDial();
}

function renderInput(q,idx){
  if(q.type==='cards'){
    return `<div class="vcards">${q.cards.map(c=>`
      <div class="vcard ${stage===c.k?'sel':''}" onclick="pickCard('${c.k}')">
        <div class="vcard-icon">${c.icon}</div>
        <div class="vcard-lbl">${c.l}</div>
      </div>`).join('')}</div>`;
  }

  if(q.type==='tags'){
    return `<div class="tags">${q.tags.map((t,i)=>{
      const sel=answers.subjects.includes(t.t);
      return `<span class="tag ${sel?'sel':''}" onclick="toggleTag(${i})">${t.t}</span>`;
    }).join('')}</div>
    <div class="tag-counter">Selected: ${answers.subjects.length} (need at least ${q.min})</div>`;
  }

  if(q.type==='text'){
    let suggestHtml='';
    if(school && school.length>1 && !schoolMatch){
      const matches=SCHOOLS.filter(s=>s.m.some(m=>m.startsWith(school.toLowerCase()))||s.name.toLowerCase().startsWith(school.toLowerCase())).slice(0,5);
      if(matches.length){
        suggestHtml=`<div class="school-suggest">${matches.map(m=>`<div class="sug-item" onclick="pickSchool('${m.name.replace(/'/g,"\\'")}')">${m.name}</div>`).join('')}</div>`;
      }
    }
    const metaTxt = schoolMatch ? `✓ Matched to ${schoolMatch.name} — we'll tailor recommendations to programs there.` : (school ? `We'll do our best with "${school}" and give you flattering general recs.` : '');
    return `<div class="text-input-wrap">
      <input class="text-input" id="school-in" type="text" placeholder="${q.placeholder}" value="${school||''}" oninput="handleSchool(this.value)" autocomplete="off">
      ${suggestHtml}
      <div class="text-meta">${metaTxt}</div>
    </div>`;
  }

  if(q.type==='pairs'){
    if(pairsIdx>=q.pairs.length){
      return `<div style="text-align:center;padding:30px 0">
        <div style="font-size:48px;margin-bottom:14px">✓</div>
        <div style="font-size:16px;font-weight:700;color:var(--green)">All set! Tap Next to continue.</div>
      </div>`;
    }
    const p=q.pairs[pairsIdx];
    return `<div class="pairs-prog">Round ${pairsIdx+1} of ${q.pairs.length}</div>
      <div class="pair-vs">
        <div class="pair-card" onclick="pickPair(${pairsIdx},'a')">${p.a.t}</div>
        <div class="pair-vs-mid">vs</div>
        <div class="pair-card" onclick="pickPair(${pairsIdx},'b')">${p.b.t}</div>
      </div>`;
  }

  if(q.type==='buckets'){
    const placed=answers.buckets;
    const unplaced=q.items.map((it,i)=>({it,i})).filter(({i})=>!placed[i]);
    let h=`<div class="bucket-items">${unplaced.map(({it,i})=>`<span class="b-item ${selectedBItem===i?'sel':''}" onclick="selectBItem(${i})">${it.t}</span>`).join('')||'<span style="color:var(--muted);font-size:13px">All sorted! ✓</span>'}</div>
    <div class="buckets">`;
    q.buckets.forEach(b=>{
      const items=Object.entries(placed).filter(([,v])=>v===b.k).map(([i])=>q.items[i]);
      h+=`<div class="bucket ${b.k} ${selectedBItem!==null?'active':''}" onclick="placeBItem('${b.k}')">
        <div class="bucket-title">${b.emoji} ${b.l}</div>
        <div class="bucket-content">${items.map((it,j)=>{const ii=q.items.indexOf(it);return `<div class="bucket-item" onclick="event.stopPropagation();unplaceBItem(${ii})">${it.t}</div>`}).join('')}</div>
      </div>`;
    });
    h+=`</div><div class="bucket-hint">${selectedBItem!==null?'Now tap a bucket to place it':'Tap an item above to pick it up'}</div>`;
    return h;
  }

  if(q.type==='vpicker'){
    const picked=answers.env;
    return `<div class="vpicker">${q.options.map((o,i)=>{
      const pi=picked.indexOf(i);
      const sel=pi!==-1?'sel':'';
      const dis=picked.length>=q.pick&&pi===-1?'disabled':'';
      return `<div class="vpick ${sel} ${dis}" onclick="pickEnv(${i})">
        ${pi!==-1?`<div class="vpick-num">${pi+1}</div>`:''}
        <div class="vpick-icon">${o.icon}</div>
        <div class="vpick-lbl">${o.l}</div>
      </div>`;
    }).join('')}</div>
    <div class="vpicker-hint">${picked.length} of ${q.pick} selected</div>`;
  }

  if(q.type==='mc'){
    const letters=['A','B','C','D','E','F'];
    return `<div class="opts">${q.opts.map((o,i)=>{
      const sel=ans[q.id]===i?'sel':'';
      return `<button class="opt ${sel}" onclick="pickMC(${q.id},${i})">
        <span class="opt-letter">${letters[i]}</span>
        <span class="opt-text">${o.t}</span>
      </button>`;
    }).join('')}</div>`;
  }

  if(q.type==='sl'){
    const v=sliders[q.key]??50;
    const bg=`linear-gradient(90deg,#3b82f6 ${v}%,#e2e8f0 ${v}%)`;
    return `<div class="slider-wrap">
      <div class="slider-labels"><span>${q.ll}</span><span>${q.rl}</span></div>
      <input type="range" min="0" max="100" value="${v}" id="sl-${q.id}"
        oninput="handleSl(${q.id},'${q.key}',this.value)"
        style="background:${bg}">
      <div class="slider-val" id="sval-${q.id}">${slLabel(q,v)}</div>
    </div>`;
  }

  if(q.type==='map2d'){
    const p=answers.map||{x:50,y:50};
    return `<div class="map2d-wrap">
      <div class="map2d" id="map2d">
        <div class="map-axis-h"></div>
        <div class="map-axis-v"></div>
        <div class="map-lbl top">${q.yTop}</div>
        <div class="map-lbl bot">${q.yBot}</div>
        <div class="map-lbl left">${q.xLeft}</div>
        <div class="map-lbl right">${q.xRight}</div>
        <div class="map-dot" id="map-dot" style="left:${p.x}%;top:${100-p.y}%"></div>
      </div>
      <div class="map-hint">Click anywhere to place yourself</div>
    </div>`;
  }

  if(q.type==='gpa'){
    const v=gpa??3.5;
    const bg=`linear-gradient(90deg,#3b82f6 ${v/4*100}%,#e2e8f0 ${v/4*100}%)`;
    const fb=gpaFeedback(v);
    return `<div class="gpa-wrap">
      <div class="gpa-display" id="gpa-disp">${v.toFixed(2)}</div>
      <div class="gpa-feedback ${fb.cls}" id="gpa-fb">${fb.txt}</div>
      <input type="range" min="0" max="40" step="1" value="${v*10}" id="gpa-sl"
        oninput="handleGpa(this.value)"
        style="background:${bg}">
      <div style="display:flex;justify-content:space-between;margin-top:8px;font-size:12px;color:var(--muted)"><span>0.0</span><span>2.0</span><span>4.0</span></div>
    </div>`;
  }

  if(q.type==='emoji'){
    const emos=['😍','🤔','😴','😬'];
    return `<div class="emoji-rows">${q.rows.map((row,i)=>`
      <div class="emoji-row">
        <div class="emoji-statement">${row.t}</div>
        <div class="emoji-pick">${emos.map((e,j)=>`
          <button class="emo-btn ${answers.emoji[i]===j?'sel':''}" onclick="pickEmoji(${i},${j})">${e}</button>
        `).join('')}</div>
      </div>`).join('')}</div>`;
  }

  if(q.type==='dial'){
    if(sliders[q.key]===undefined) sliders[q.key]=50;
    const v=sliders[q.key];
    const labels=Array.isArray(q.labels)?q.labels:['Calm','Easy','Active','High','Pressure'];
    const lblIdx=Math.max(0,Math.min(labels.length-1,Math.floor(v/(100/labels.length))));
    // arc dial from -180deg (left) through -90 (top) to 0 (right)
    const angleRad=(v/100*180-180)*Math.PI/180;
    const cx=120,cy=120,rad=100;
    const rx=cx+rad*Math.cos(angleRad);
    const ry=cy+rad*Math.sin(angleRad);
    return `<div class="dial-wrap">
      <svg class="dial-svg" viewBox="0 0 240 140" id="dial-svg" onclick="handleDialClick(event)">
        <path d="M 20 120 A 100 100 0 0 1 220 120" stroke="#e2e8f0" stroke-width="10" fill="none" stroke-linecap="round"/>
        <path d="M 20 120 A 100 100 0 0 1 ${rx.toFixed(2)} ${ry.toFixed(2)}" stroke="#3b82f6" stroke-width="10" fill="none" stroke-linecap="round"/>
        <line x1="${cx}" y1="${cy}" x2="${rx.toFixed(2)}" y2="${ry.toFixed(2)}" stroke="#1a56db" stroke-width="4" stroke-linecap="round"/>
        <circle cx="${cx}" cy="${cy}" r="10" fill="#1a56db"/>
      </svg>
      <div class="dial-val">${v}</div>
      <div class="dial-lbl">${labels[lblIdx]}</div>
      <input type="range" min="0" max="100" value="${v}" style="width:240px;margin-top:14px;background:linear-gradient(90deg,#3b82f6 ${v}%,#e2e8f0 ${v}%)" oninput="handleDialSlide(this.value)">
    </div>`;
  }

  if(q.type==='tiers'){
    const placed=answers.tiers;
    const unplaced=q.items.map((it,i)=>({it,i})).filter(({i})=>placed[i]===undefined);
    let h=`<div class="tier-pool">${unplaced.map(({it,i})=>`<span class="t-item ${selectedTItem===i?'sel':''}" onclick="selectTItem(${i})">${it.t}</span>`).join('')||'<span style="color:var(--muted);font-size:13px">All tiered ✓</span>'}</div>
    <div class="tiers">`;
    q.tierList.forEach(t=>{
      const items=Object.entries(placed).filter(([,v])=>v===t.k).map(([i])=>q.items[i]);
      h+=`<div class="tier-row">
        <div class="tier-lbl ${t.k}" onclick="placeTItem('${t.k}')">${t.k}</div>
        <div class="tier-zone ${selectedTItem!==null?'active':''}" onclick="placeTItem('${t.k}')">
          ${items.map(it=>{const ii=q.items.indexOf(it);return `<div class="tier-item" onclick="event.stopPropagation();unplaceTItem(${ii})">${it.t}</div>`}).join('')}
        </div>
      </div>`;
    });
    h+=`</div><div class="tier-hint">${selectedTItem!==null?'Tap a tier letter to place':'Tap an item above to pick it up'}</div>`;
    return h;
  }

  if(q.type==='spec'){
    const sel=answers.spectrum;
    return `<div class="spec-track-wrap">
      <div class="spec-track">
        ${q.stops.map((s,i)=>`<div class="spec-marker ${sel===i?'sel':''}" style="left:${i/(q.stops.length-1)*100}%" onclick="pickSpec(${i})"></div>`).join('')}
      </div>
      <div class="spec-stops">${q.stops.map((s,i)=>`<div class="spec-stop ${sel===i?'sel':''}" onclick="pickSpec(${i})">${s.l}</div>`).join('')}</div>
      <div class="spec-display">${sel!==null?'Selected: '+q.stops[sel].l:'Tap a stop along the spectrum'}</div>
    </div>`;
  }

  if(q.type==='budget'){
    const total=Object.values(budget).reduce((a,b)=>a+b,0);
    const remCls=total===100?'ok':total>100?'over':'';
    return `<div class="budget-info">
      <span>Total allocated: <strong>${total}</strong> / 100</span>
      <span class="budget-rem ${remCls}">${total===100?'✓ Perfect':total>100?'Over by '+(total-100):(100-total)+' remaining'}</span>
    </div>
    <div class="budget-rows">${q.categories.map(c=>{
      const v=budget[c.k];
      return `<div class="budget-row">
        <div class="budget-lbl">${c.l}</div>
        <div class="budget-bar-wrap">
          <div class="budget-bar"><div class="budget-fill" style="width:${v}%"></div></div>
          <input type="range" min="0" max="50" value="${v}" oninput="handleBudget('${c.k}',this.value)">
        </div>
        <div class="budget-val">${v}</div>
      </div>`;
    }).join('')}</div>`;
  }

  if(q.type==='swipe'){
    if(swipeIdx>=q.cards.length){
      return `<div style="text-align:center;padding:30px 0">
        <div style="font-size:48px;margin-bottom:14px">✓</div>
        <div style="font-size:16px;font-weight:700;color:var(--green)">All swiped! Tap Next.</div>
      </div>`;
    }
    const card=q.cards[swipeIdx];
    return `<div class="swipe-prog">Card ${swipeIdx+1} of ${q.cards.length}</div>
      <div class="swipe-card">${card.t}</div>
      <div class="swipe-btns">
        <button class="sw-btn sw-no" onclick="swipeCard(${swipeIdx},false)">✕ No</button>
        <button class="sw-btn sw-yes" onclick="swipeCard(${swipeIdx},true)">✓ Yes</button>
      </div>`;
  }

  if(q.type==='rank'){
    const ranked=answers.rank[q.id]||[];
    let h=`<div class="rank-hint">${q.sub||'Tap items in order from 1 to '+q.items.length+'.'}</div><div class="rank-list">`;
    q.items.forEach((item,i)=>{
      const ri=ranked.indexOf(i);
      const rked=ri!==-1?'rked':'';
      h+=`<div class="rank-item ${rked}" onclick="handleRank(${q.id},${i})">
        <div class="rank-badge">${ri!==-1?ri+1:''}</div>
        <div class="rank-text">${item.t}</div>
      </div>`;
    });
    return h+`</div>`;
  }

  return '';
}

// INPUT HANDLERS
function pickCard(k){stage=k;answers.stage=k;renderQ(cur);checkCombos();}

function toggleTag(i){
  const q=Qs[1];
  const t=q.tags[i].t;
  const idx=answers.subjects.indexOf(t);
  if(idx>-1) answers.subjects.splice(idx,1);
  else if(answers.subjects.length<q.max) answers.subjects.push(t);
  renderQ(cur);
  checkCombos();
}

function handleSchool(v){
  school=v;
  schoolMatch=null;
  if(v && v.length>0){
    const lc=v.toLowerCase().trim();
    schoolMatch=SCHOOLS.find(s=>s.m.some(m=>lc===m)||s.name.toLowerCase()===lc);
  }
  renderQ(cur);
  setTimeout(()=>{
    const inp=document.getElementById('school-in');
    if(inp){inp.focus();inp.setSelectionRange(v.length,v.length);}
  },0);
}

function pickSchool(name){
  school=name;
  schoolMatch=SCHOOLS.find(s=>s.name===name);
  renderQ(cur);
}

function pickPair(idx,which){
  const q=Qs[3];
  answers.pairs[idx]=which;
  pairsIdx++;
  renderQ(cur);
  checkCombos();
}

function selectBItem(i){selectedBItem=selectedBItem===i?null:i;renderQ(cur);}
function placeBItem(bucket){
  if(selectedBItem===null) return;
  answers.buckets[selectedBItem]=bucket;
  selectedBItem=null;
  renderQ(cur);
  checkCombos();
}
function unplaceBItem(i){delete answers.buckets[i];renderQ(cur);}

function pickEnv(i){
  const q=Qs[5];
  const pi=answers.env.indexOf(i);
  if(pi!==-1) answers.env.splice(pi,1);
  else if(answers.env.length<q.pick) answers.env.push(i);
  renderQ(cur);
  checkCombos();
}

function pickMC(qId,i){
  ans[qId]=i;
  const q=Qs[qId];
  if(q.key==='major') answers.major=q.opts[i].k;
  renderQ(cur);
  checkCombos();
}

function handleSl(qId,key,val){
  val=parseInt(val);
  sliders[key]=val;
  const el=document.getElementById(`sl-${qId}`);
  if(el) el.style.background=`linear-gradient(90deg,#3b82f6 ${val}%,#e2e8f0 ${val}%)`;
  const disp=document.getElementById(`sval-${qId}`);
  if(disp) disp.textContent=slLabel(Qs[qId],val);
  checkCombos();
}

function slLabel(q,v){v=parseInt(v);if(v<20)return q.ll;if(v<42)return`Leaning: ${q.ll}`;if(v<58)return'Balanced';if(v<80)return`Leaning: ${q.rl}`;return q.rl;}

function setupMap(){
  const m=document.getElementById('map2d');
  if(!m) return;
  const handle=e=>{
    const rect=m.getBoundingClientRect();
    const ev=e.touches?e.touches[0]:e;
    const x=Math.max(0,Math.min(100,(ev.clientX-rect.left)/rect.width*100));
    const y=Math.max(0,Math.min(100,100-(ev.clientY-rect.top)/rect.height*100));
    answers.map={x:r(x),y:r(y)};
    const d=document.getElementById('map-dot');
    if(d){d.style.left=x+'%';d.style.top=(100-y)+'%';}
    checkCombos();
  };
  m.addEventListener('click',handle);
  let dragging=false;
  m.addEventListener('mousedown',()=>dragging=true);
  document.addEventListener('mouseup',()=>dragging=false);
  m.addEventListener('mousemove',e=>{if(dragging)handle(e);});
  m.addEventListener('touchstart',handle,{passive:true});
  m.addEventListener('touchmove',handle,{passive:true});
}

function handleGpa(v){
  v=parseFloat(v)/10;
  gpa=v;
  const disp=document.getElementById('gpa-disp');
  if(disp) disp.textContent=v.toFixed(2);
  const fb=gpaFeedback(v);
  const fbEl=document.getElementById('gpa-fb');
  if(fbEl){fbEl.textContent=fb.txt;fbEl.className=`gpa-feedback ${fb.cls}`;}
  const sl=document.getElementById('gpa-sl');
  if(sl) sl.style.background=`linear-gradient(90deg,#3b82f6 ${v/4*100}%,#e2e8f0 ${v/4*100}%)`;
  checkCombos();
}

function gpaFeedback(v){
  if(v>=3.9) return {cls:'elite',txt:'🏆 Elite — every door is wide open for you.'};
  if(v>=3.7) return {cls:'great',txt:'⭐ Outstanding — top programs will compete for you.'};
  if(v>=3.4) return {cls:'good',txt:'✓ Strong — you have your pick of solid programs.'};
  if(v>=3.0) return {cls:'',txt:'Solid foundation — focus and direction matter more than perfection.'};
  return {cls:'',txt:'Numbers don\'t define trajectory. What you build next does.'};
}

function pickEmoji(rowIdx,emoIdx){answers.emoji[rowIdx]=emoIdx;renderQ(cur);checkCombos();}

function setupDial(){
  const svg=document.getElementById('dial-svg');
  if(!svg) return;
}

function handleDialClick(e){
  const svg=document.getElementById('dial-svg');
  if(!svg) return;
  const rect=svg.getBoundingClientRect();
  const x=(e.clientX-rect.left)/rect.width*240;
  const y=(e.clientY-rect.top)/rect.height*140;
  const dx=x-120, dy=y-120;
  // The arc covers the upper half (dy <= 0). Compute angle in degrees.
  let angle=Math.atan2(dy,dx)*180/Math.PI;
  // Clamp below-center clicks to nearest end of arc
  if(angle>0) angle = dx<0 ? -180 : 0;
  // angle is now in [-180, 0]. Map: -180 -> 0, 0 -> 100
  const v=Math.max(0,Math.min(100,((angle+180)/180)*100));
  sliders.intensity=r(v);
  renderQ(cur);
  checkCombos();
}

function handleDialSlide(v){
  sliders.intensity=parseInt(v);
  renderQ(cur);
  checkCombos();
}

function selectTItem(i){selectedTItem=selectedTItem===i?null:i;renderQ(cur);}
function placeTItem(tier){
  if(selectedTItem===null) return;
  if(!answers.tiers) answers.tiers={};
  answers.tiers[selectedTItem]=tier;
  selectedTItem=null;
  renderQ(cur);
  checkCombos();
}
function unplaceTItem(i){delete answers.tiers[i];renderQ(cur);}

function pickSpec(i){answers.spectrum=i;renderQ(cur);checkCombos();}

function handleBudget(k,v){
  budget[k]=parseInt(v);
  renderQ(cur);
  checkCombos();
}

function swipeCard(idx,yes){
  answers.swipes[idx]=yes;
  swipeIdx++;
  renderQ(cur);
  checkCombos();
}

function handleRank(qId,itemIdx){
  let ranked=answers.rank[qId]?[...answers.rank[qId]]:[];
  if(ranked.includes(itemIdx)) ranked=ranked.filter(x=>x!==itemIdx);
  else ranked.push(itemIdx);
  answers.rank[qId]=ranked;
  renderQ(cur);
}

function canNext(q){
  if(q.type==='cards') return stage!==null;
  if(q.type==='tags') return answers.subjects.length>=q.min;
  if(q.type==='text') return school && school.trim().length>=2;
  if(q.type==='pairs') return pairsIdx>=q.pairs.length;
  if(q.type==='buckets') return Object.keys(answers.buckets).length===q.items.length;
  if(q.type==='vpicker') return answers.env.length===q.pick;
  if(q.type==='mc') return ans[q.id]!==undefined;
  if(q.type==='sl') return true;
  if(q.type==='map2d') return answers.map!==null;
  if(q.type==='gpa') return gpa!==null;
  if(q.type==='emoji') return Object.keys(answers.emoji).length===q.rows.length;
  if(q.type==='dial') return sliders.intensity!==undefined;
  if(q.type==='tiers') return Object.keys(answers.tiers||{}).length===q.items.length;
  if(q.type==='spec') return answers.spectrum!==null;
  if(q.type==='budget') return Object.values(budget).reduce((a,b)=>a+b,0)===100;
  if(q.type==='swipe') return swipeIdx>=q.cards.length;
  if(q.type==='rank') return (answers.rank[q.id]||[]).length===q.items.length;
  return true;
}

function goNext(){
  if(!canNext(Qs[cur])) return;
  if(cur===Qs.length-1){showResults();return;}
  slide(()=>{cur++;renderQ(cur);});
}

function forceNext(){
  if(cur===Qs.length-1){showResults();return;}
  slide(()=>{cur++;renderQ(cur);});
}

function goBack(){
  if(cur===0) return;
  slide(()=>{cur--;renderQ(cur);},true);
}

function slide(cb,back=false){
  const card=document.getElementById('qcard');
  card.style.opacity='0';
  card.style.transform=`translateX(${back?'30px':'-30px'})`;
  setTimeout(()=>{
    cb();
    card.style.transition='none';
    card.style.transform=`translateX(${back?'-30px':'30px'})`;
    card.style.opacity='0';
    requestAnimationFrame(()=>requestAnimationFrame(()=>{
      card.style.transition='opacity .22s,transform .22s';
      card.style.transform='translateX(0)';
      card.style.opacity='1';
    }));
  },200);
}

// SCORING
function computeScores(){
  const sc={};
  Object.keys(IND).forEach(k=>sc[k]=0);
  const add=(s,m=1)=>{if(!s)return;Object.entries(s).forEach(([k,v])=>{if(sc[k]!==undefined)sc[k]+=v*m})};

  // Tags
  const tagQ=Qs[1];
  answers.subjects.forEach(t=>{
    const tag=tagQ.tags.find(x=>x.t===t);
    if(tag) add(tag.s);
  });

  // Pairs
  const pq=Qs[3];
  Object.entries(answers.pairs).forEach(([i,w])=>{
    const p=pq.pairs[i];
    add(p[w].s,2);
  });

  // Buckets
  const bq=Qs[4];
  Object.entries(answers.buckets).forEach(([i,bkey])=>{
    const item=bq.items[i];
    const bucket=bq.buckets.find(b=>b.k===bkey);
    add(item.s, bucket.mult);
  });

  // Vpicker
  const vq=Qs[5];
  answers.env.forEach(i=>add(vq.options[i].s));

  // MCs (Q6, Q17, Q18, Q19)
  [6,17,18,19].forEach(qId=>{
    if(ans[qId]!==undefined) add(Qs[qId].opts[ans[qId]].s,2);
  });

  // Slider Q7 risk
  if(sliders.risk!==undefined) add(Qs[7].score(sliders.risk));

  // Map Q8
  if(answers.map) add(Qs[8].score(answers.map));

  // Emoji Q10
  const eq=Qs[10];
  Object.entries(answers.emoji).forEach(([i,e])=>{
    const row=eq.rows[i];
    // 😍=love(+3), 🤔=curious(+1), 😴=bored(0), 😬=anxious(-1)
    const mult=[3,1,0,-1][e];
    row.ind.forEach(ind=>{if(sc[ind]!==undefined)sc[ind]+=mult});
  });

  // Dial Q11
  if(sliders.intensity!==undefined) add(Qs[11].score(sliders.intensity));

  // Tiers Q12
  const tq=Qs[12];
  Object.entries(answers.tiers).forEach(([i,t])=>{
    const item=tq.items[i];
    const tier=tq.tierList.find(x=>x.k===t);
    add(item.s, tier.mult);
  });

  // Spectrum Q13
  if(answers.spectrum!==null) add(Qs[13].stops[answers.spectrum].s,2);

  // Budget Q14
  const bgQ=Qs[14];
  bgQ.categories.forEach(c=>{
    const v=budget[c.k];
    add(c.s, v/8); // normalize so a 30-point cat gives ~3.75 multiplier
  });

  // Swipes Q15
  const sw=Qs[15];
  Object.entries(answers.swipes).forEach(([i,y])=>{
    const card=sw.cards[i];
    add(y?card.y:card.n);
  });

  // Rank Q16
  const rq=Qs[16];
  const ranked=answers.rank[16]||[];
  ranked.slice(0,3).forEach((itemIdx,rank)=>{
    const w=[3,2,1][rank];
    add(rq.items[itemIdx].s, w);
  });

  // Boost based on major fit (Q18)
  if(answers.major){
    const map={cs:{tech:2},eng:{engineering:2},biz:{business:2,finance:1},med:{healthcare:2},hum:{creative:1,education:1},soc:{social:1,education:1},art:{creative:2}};
    if(map[answers.major]) add(map[answers.major],2);
  }

  return sc;
}

function showResults(){
  document.getElementById('quiz').classList.add('hidden');
  document.getElementById('results').classList.remove('hidden');

  const sc=computeScores();
  const sorted=Object.entries(sc).sort((a,b)=>b[1]-a[1]).slice(0,4);
  const maxSc=sorted[0][1]||1;

  const archetype=determineArchetype();
  const blurb=generateBlurb(sorted.map(x=>x[0]));

  let h=`<div class="res-hdr">
    <div class="res-eye">Your Career Profile</div>
    <div class="res-title">Your Top Industry Matches</div>
    <div class="res-sub">Personalized based on 20 data points about how you think, work, and lead.</div>
  </div>`;

  // GPA banner
  if(gpa!==null){
    const fb=gpaFeedback(gpa);
    const gMsg=gpaMessage();
    h+=`<div class="gpa-banner ${fb.cls||'solid'}">${gMsg}</div>`;
  }

  // Archetype
  h+=`<div class="archetype-card">
    <div class="arche-eye">You Are</div>
    <div class="arche-name">${archetype.name}</div>
    <div class="arche-blurb">${blurb}</div>
  </div>`;

  sorted.forEach(([key,score],i)=>{
    const ind=IND[key];
    const pct=Math.round((score/maxSc)*100);
    const why=industryWhy(key);
    const schoolBlock=schoolBlurb(key);
    h+=`<div class="ind-card ${i===0?'top':''}">
      <div class="ind-head">
        <div class="ind-rank">${i+1}</div>
        <div class="ind-name">${ind.icon} ${ind.name}</div>
        <div class="ind-pct">${pct}%</div>
      </div>
      <div class="ind-bar"><div class="ind-bar-fill" style="width:${pct}%"></div></div>
      <div class="ind-why">${why}</div>
      ${schoolBlock}
    </div>`;
  });

  h+=`<button class="restart" onclick="restartQuiz()">↺ Retake Assessment</button>`;
  document.getElementById('rcard').innerHTML=h;
  window.scrollTo({top:0,behavior:'smooth'});
}

// ARCHETYPES
function determineArchetype(){
  const techy=answers.subjects.some(t=>['💻 Tech / Coding','🧮 Math','🏗️ Engineering'].includes(t));
  const creative=answers.subjects.some(t=>['🎨 Art & Design','🎵 Music','🎬 Film','✍️ Writing','📷 Photography'].includes(t));
  const helpful=answers.subjects.some(t=>['🩺 Medicine','🧠 Psychology','🌍 Global Issues'].includes(t));
  const map=answers.map||{x:50,y:50};
  const risk=sliders.risk||50;
  const intensity=sliders.intensity||50;

  if(techy && creative && map.y>55) return {name:'The Technical Creative',k:'tcr'};
  if(risk>65 && (budget.salary||0)<20 && map.y>50) return {name:'The Visionary Builder',k:'vis'};
  if(risk>65 && (budget.growth||0)>20) return {name:'The Entrepreneurial Force',k:'ent'};
  if(helpful && map.x>55) return {name:'The Connector-Healer',k:'con'};
  if((budget.purpose||0)>=22 && intensity<55) return {name:'The Purpose-Driven Idealist',k:'pur'};
  if(gpa>=3.8 && answers.subjects.some(t=>['🔬 Science','🤔 Philosophy','📜 History','🧮 Math'].includes(t))) return {name:'The Scholar',k:'sch'};
  if(map.y<45 && (budget.salary||0)>=22) return {name:'The Strategic Operator',k:'op'};
  if(map.x>60 && (budget.recog||0)>=18) return {name:'The Natural Leader',k:'ldr'};
  if(creative && risk>55) return {name:'The Bold Creative',k:'bcr'};
  if(techy && map.y<45) return {name:'The Systems Thinker',k:'sys'};
  return {name:'The Multi-Threat',k:'mt'};
}

function generateBlurb(top){
  const arch=determineArchetype();
  const traits=[];
  const map=answers.map||{x:50,y:50};

  if(map.y>60) traits.push("a strong creative instinct");
  else if(map.y<40) traits.push("a clear preference for structure and rigor");
  if(map.x>60) traits.push("real energy from collaboration");
  else if(map.x<40) traits.push("the focus to do deep solo work");

  if((budget.salary||0)>=25) traits.push("ambition about compensation");
  if((budget.purpose||0)>=25) traits.push("a commitment to meaningful impact");
  if((budget.flex||0)>=20) traits.push("a non-negotiable need for flexibility");

  if(sliders.risk>70) traits.push("unusual risk tolerance");
  if(sliders.intensity>70) traits.push("an appetite for high-tempo work");
  else if(sliders.intensity<35) traits.push("the discipline to value sustainable pace");

  const traitStr = traits.length>2 ? traits.slice(0,3).join(', ') : traits.join(' and ');

  let intro = `You combine ${traitStr}. That's an unusual blend — and it's exactly the kind of profile that does well in the industries below.`;

  if(gpa!==null && gpa>=3.7){
    intro += ` Your ${gpa.toFixed(2)} GPA tells admissions committees and employers you can execute under pressure — which opens nearly every door.`;
  }

  return intro;
}

function gpaMessage(){
  if(gpa>=3.9) return `🏆 With a ${gpa.toFixed(2)} GPA, every elite program in America is realistically within reach. Don't undersell yourself — top consulting firms, top med schools, top law schools, and top grad programs will all take your application seriously.`;
  if(gpa>=3.7) return `⭐ A ${gpa.toFixed(2)} GPA is an exceptional asset. You're competitive for top-tier graduate programs and the most selective recruiting tracks at top companies.`;
  if(gpa>=3.4) return `✓ A ${gpa.toFixed(2)} GPA gives you real optionality. Strong graduate programs and competitive employers will look at you carefully — and what you build outside the classroom matters more from here.`;
  if(gpa>=3.0) return `Your ${gpa.toFixed(2)} GPA is a solid foundation. From here, what differentiates you isn't grades — it's the specific things you build, lead, and ship.`;
  return `Your GPA is one input among many. Some of the most successful people in every industry below had average grades — what mattered was relentless work outside the classroom.`;
}

// INDUSTRY WHY (personalized reasoning)
function industryWhy(key){
  const reasons=[];
  const ind=IND[key];

  // Industry-specific personalized reasons
  const subs=answers.subjects;
  const map=answers.map||{x:50,y:50};

  if(key==='tech'){
    if(subs.includes('💻 Tech / Coding')||subs.includes('🧮 Math')) reasons.push(`Your love of ${subs.includes('💻 Tech / Coding')?'tech':'math'} maps directly into the field.`);
    if(map.y<50) reasons.push("Your structured thinking is exactly what software engineering rewards.");
    if((budget.flex||0)>=18) reasons.push("Tech offers more flexibility and remote optionality than almost any field.");
    if(sliders.risk>60) reasons.push("Your risk tolerance suits an industry where moving fast pays.");
  } else if(key==='healthcare'){
    if(subs.includes('🩺 Medicine')||subs.includes('🔬 Science')) reasons.push("Your interest in medicine and science is the foundation of this work.");
    if(map.x>50) reasons.push("Healthcare is fundamentally about people — your collaborative energy fits.");
    if((budget.purpose||0)>=18) reasons.push("Few fields offer more direct, tangible impact on individual lives.");
    if((budget.security||0)>=18) reasons.push("Healthcare careers offer some of the highest job security in the economy.");
  } else if(key==='finance'){
    if(subs.includes('📈 Economics')||subs.includes('🧮 Math')) reasons.push("Your quantitative interests map directly to finance's core skill set.");
    if((budget.salary||0)>=22) reasons.push("Few industries pay as well as finance for top performers — your goals fit.");
    if(map.y<50) reasons.push("Your appreciation for structure is essential to thriving in finance.");
    if(sliders.intensity>60) reasons.push("Finance rewards high-intensity work — and that's the pace you want.");
  } else if(key==='creative'){
    if(subs.some(s=>['🎨 Art & Design','🎵 Music','🎬 Film','✍️ Writing','📷 Photography'].includes(s))) reasons.push("Your creative interests are obvious — this isn't a stretch, it's a calling.");
    if(map.y>55) reasons.push("You scored as highly creative — this field is built for people like you.");
    if((budget.flex||0)>=18) reasons.push("Creative work tends to allow the autonomy and flexibility you want.");
  } else if(key==='education'){
    if(subs.some(s=>['🤔 Philosophy','📜 History','✍️ Writing','🌍 Global Issues','🧠 Psychology'].includes(s))) reasons.push("Your intellectual interests are the soil from which great teachers grow.");
    if((budget.purpose||0)>=18) reasons.push("Education is one of the highest-leverage ways to make lasting impact.");
    if(map.x>50) reasons.push("Teaching is fundamentally relational — your people-orientation fits.");
  } else if(key==='business'){
    if(subs.includes('💼 Business')||subs.includes('📈 Economics')) reasons.push("Your interest in business and economics is a direct fit.");
    if(map.x>55) reasons.push("Consulting and business leadership reward your collaborative style.");
    if((budget.growth||0)>=18) reasons.push("Few fields offer faster early-career growth than top business roles.");
    if((budget.recog||0)>=18) reasons.push("Business leadership offers the visibility and recognition you value.");
  } else if(key==='law'){
    if(subs.some(s=>['⚖️ Politics','📜 History','🤔 Philosophy','✍️ Writing'].includes(s))) reasons.push("Your interests in argument, history, and reasoning are the bedrock of legal thinking.");
    if(map.y<50) reasons.push("Your preference for structure and precision suits legal work perfectly.");
    if((budget.recog||0)>=18) reasons.push("Law offers prestige and recognition few professions match.");
  } else if(key==='engineering'){
    if(subs.includes('🏗️ Engineering')||subs.includes('🧮 Math')||subs.includes('🔬 Science')) reasons.push("Your technical and analytical interests are exactly what engineering demands.");
    if(map.y<55) reasons.push("Your structured thinking is essential for engineering rigor.");
    if((budget.security||0)>=15) reasons.push("Engineering offers strong, stable career paths with high earning potential.");
  } else if(key==='science'){
    if(subs.includes('🔬 Science')||subs.includes('🌿 Nature')||subs.includes('🩺 Medicine')) reasons.push("Your scientific curiosity is the prerequisite — and you have it in abundance.");
    if(gpa>=3.7) reasons.push("Your GPA signals you can handle rigorous graduate-level research.");
    if(sliders.intensity<55) reasons.push("Research rewards patience and sustained focus — your work style fits.");
  } else if(key==='startups'){
    if(sliders.risk>60) reasons.push("Your risk tolerance is essential for the startup path — most can't handle it.");
    if((budget.growth||0)>=20) reasons.push("Startups offer the steepest learning curve in any career.");
    if((budget.salary||0)<20) reasons.push("Your willingness to delay reward fits the startup payout curve.");
    if(map.y>55) reasons.push("Your creative orientation suits the build-from-nothing nature of startups.");
  } else if(key==='social'){
    if(subs.some(s=>['🌍 Global Issues','🧠 Psychology','📜 History','⚖️ Politics'].includes(s))) reasons.push("Your interests in people, systems, and justice point straight here.");
    if((budget.purpose||0)>=22) reasons.push("Mission-driven work is exactly what your values point you toward.");
    if(map.x>55) reasons.push("Social impact is built on collaboration — your team orientation fits.");
  } else if(key==='marketing'){
    if(subs.some(s=>['🎬 Film','✍️ Writing','🎨 Art & Design','📷 Photography'].includes(s))) reasons.push("Your creative interests give you natural intuition for what moves audiences.");
    if(map.x>50) reasons.push("Marketing is fundamentally about understanding people — your orientation fits.");
    if((budget.flex||0)>=18) reasons.push("Modern marketing offers remote and flexible career structures.");
  }

  if(reasons.length===0) reasons.push("Your overall profile shows strong alignment with this field's core demands.");

  return reasons.slice(0,3).join(' ');
}

function schoolBlurb(industryKey){
  if(!school) return '';
  if(schoolMatch){
    const prog=schoolMatch.p[industryKey];
    if(prog){
      return `<div class="ind-school">
        <strong>Why ${schoolMatch.name} is the right place</strong>
        <div class="major">Recommended major: ${prog.maj}</div>
        <div>${prog.w}</div>
        <div class="ind-classes"><strong>Try these classes:</strong> ${prog.cl}</div>
      </div>`;
    }
    // School matched but no program data for this industry — generic flatter
    return `<div class="ind-school">
      <strong>${schoolMatch.name} for this path</strong>
      <div>${schoolMatch.name} has a strong tradition that supports students entering ${IND[industryKey].name.toLowerCase()}. Talk to advisors about cross-listed coursework — flexibility here is an advantage.</div>
    </div>`;
  }
  // Unknown school — flatter generically
  return `<div class="ind-school">
    <strong>Making ${school} work for you</strong>
    <div>${school} has people who've gone into ${IND[industryKey].name.toLowerCase()} — find them. Look for majors that overlap with ${IND[industryKey].name.split(' ')[0]}, and seek mentors who've made the leap. Your school is what you make of it.</div>
  </div>`;
}

// COMBOS
function checkCombos(){
  const state={
    answers, sliders, budget,
    gpa: gpa??0, school, subjects:answers.subjects,
    spectrum:answers.spectrum
  };
  COMBOS.forEach(c=>{
    if(!shownCombos.has(c.id) && c.check(state)){
      shownCombos.add(c.id);
      setTimeout(()=>showCombo(c),300);
    }
  });
}

function showCombo(c){
  document.getElementById('clbl').textContent=c.lbl;
  const lbl=document.getElementById('clbl');
  lbl.style.background=`linear-gradient(135deg,${c.color},#f59e0b)`;
  lbl.style.webkitBackgroundClip='text';
  lbl.style.webkitTextFillColor='transparent';
  lbl.style.backgroundClip='text';
  document.getElementById('ctitle').textContent=c.title;
  document.getElementById('cdesc').textContent=c.desc;
  document.getElementById('combo-overlay').classList.add('vis');
}

function closeCombo(){document.getElementById('combo-overlay').classList.remove('vis');}

function restartQuiz(){
  cur=0; ans={}; sliders={};
  answers={pairs:{},buckets:{},env:[],map:null,emoji:{},swipes:{},tiers:{},rank:{},major:null,spectrum:null,subjects:[]};
  budget={salary:17,purpose:17,flex:16,growth:17,recog:16,security:17};
  gpa=null; school=null; schoolMatch=null; stage=null;
  shownCombos=new Set();
  pairsIdx=0; swipeIdx=0; selectedBItem=null; selectedTItem=null;
  document.getElementById('results').classList.add('hidden');
  document.getElementById('intro').classList.remove('hidden');
}
